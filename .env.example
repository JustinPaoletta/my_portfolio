# Copy this file to .env for local development.
# Client-side values must use the VITE_ prefix.
# Server-only values for Vercel functions are listed at the bottom as comments.

# App
VITE_APP_TITLE=JP Engineering
VITE_APP_DESCRIPTION=Portfolio of Justin Paoletta, a software engineer building accessible, performant web applications with React, TypeScript, Angular, and modern frontend tooling.
VITE_SITE_URL=https://jpengineering.dev

# Client API config
VITE_API_URL=http://localhost:3000/api
VITE_API_TIMEOUT=5000

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ERROR_MONITORING=false

# Social links
VITE_GITHUB_URL=https://github.com/JustinPaoletta
VITE_LINKEDIN_URL=https://www.linkedin.com/in/justin-paoletta/
VITE_EMAIL=justinpaoletta@gmail.com

# GitHub data
VITE_GITHUB_USERNAME=JustinPaoletta
VITE_GITHUB_API_ENABLED=false

# Optional analytics
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SRC=https://cloud.umami.is/script.js
VITE_GOOGLE_ANALYTICS_ID=

# Optional error monitoring
VITE_NEWRELIC_ACCOUNT_ID=
VITE_NEWRELIC_TRUST_KEY=
VITE_NEWRELIC_AGENT_ID=
VITE_NEWRELIC_LICENSE_KEY=
VITE_NEWRELIC_APPLICATION_ID=
VITE_NEWRELIC_AJAX_DENY_LIST=

# Optional third-party services
VITE_MAPBOX_TOKEN=

# Server-only environment variables for Vercel functions
# GITHUB_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# RESEND_API_KEY=
# CONTACT_EMAIL=
# RESEND_FROM_EMAIL=
